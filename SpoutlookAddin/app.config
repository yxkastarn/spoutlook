<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
  <appSettings>
    <!--
      Register your Spotify application at https://developer.spotify.com/dashboard
      and set the Redirect URI to http://localhost:5678/callback, then paste
      your Client ID here.  Do NOT commit this file with a real Client ID to
      public source control.
    -->
    <add key="SpotifyClientId" value="YOUR_SPOTIFY_CLIENT_ID" />
  </appSettings>
</configuration>
