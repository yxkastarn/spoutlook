<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui"
          onLoad="Ribbon_Load">
  <ribbon>
    <tabs>
      <tab idMso="TabMail">
        <group id="SpoutlookGroup" label="Spoutlook">
          <toggleButton id="BtnTogglePlayer"
                        label="Mini Player"
                        screentip="Spoutlook Mini Player"
                        supertip="Toggle the Spoutlook mini-player (Spotify or TuneIn)"
                        size="large"
                        imageMso="MusicInsert"
                        onAction="BtnTogglePlayer_Click"
                        getPressed="BtnTogglePlayer_GetPressed"/>
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
