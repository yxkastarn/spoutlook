{
  "env": { "browser": true, "es2021": true },
  "extends": "eslint:recommended",
  "parserOptions": { "ecmaVersion": 2021 },
  "globals": {
    "Office": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "varsIgnorePattern": "^(selectSource|connectSpotify|disconnectSpotify|debounceSpotifySearch|debounceTuneInSearch|stopTuneIn)$" }]
  }
}
